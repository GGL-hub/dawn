<section class="gexon-home color-{{ section.settings.color_scheme }}">
  <div
    class="gexon-hero"
    {% if section.settings.hero_image == blank %}
      style="--gexon-hero-image: url('{{ section.settings.hero_image_url }}');"
    {% endif %}
  >
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'gexon-hero__image',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high'
      }}
    {%- else -%}
      <div class="gexon-hero__photo" aria-hidden="true"></div>
    {%- endif -%}
    <div class="gexon-hero__overlay"></div>
    <div class="page-width gexon-hero__content">
      <p class="gexon-eyebrow">{{ section.settings.hero_kicker }}</p>
      <h1>{{ section.settings.hero_heading }}</h1>
      <p>{{ section.settings.hero_text }}</p>
      <div class="gexon-actions">
        <a class="button button--primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="gexon-hero__brand" aria-hidden="true">
      <img src="{{ 'gexon-logo.png' | asset_url }}" alt="" width="520" height="160">
    </div>
    <div class="gexon-hero__dots" aria-hidden="true">
      <span class="is-active"></span>
      <span></span>
      <span></span>
    </div>
  </div>

  <div class="gexon-section gexon-section--dark">
    <div class="page-width">
      <div class="gexon-section-heading">
        <p class="gexon-eyebrow">Shop by category</p>
        <h2>Equipment for every training goal</h2>
      </div>
      <div class="gexon-category-showcase">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category_card' -%}
            <a
              class="gexon-category-tile"
              href="{{ block.settings.link }}"
              style="--tile-image: url('{{ block.settings.image_url }}');"
              {{ block.shopify_attributes }}
            >
              <span>{{ block.settings.kicker }}</span>
              <strong>{{ block.settings.title }}</strong>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="gexon-section gexon-section--products">
    <div class="page-width">
      <div class="gexon-section-heading gexon-section-heading--split">
        <div>
          <p class="gexon-eyebrow">Featured products</p>
          <h2>{{ section.settings.featured_heading }}</h2>
        </div>
        {%- if section.settings.featured_link != blank -%}
          <a class="gexon-text-link" href="{{ section.settings.featured_link }}">View all</a>
        {%- endif -%}
      </div>
      <div class="gexon-product-grid">
        {%- if section.settings.featured_collection != blank and section.settings.featured_collection.products.size > 0 -%}
          {%- for product in section.settings.featured_collection.products limit: 4 -%}
            <div class="gexon-product">
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: 'square',
                image_shape: 'default',
                show_secondary_image: true,
                show_vendor: true,
                show_rating: false,
                lazy_load: true,
                section_id: section.id,
                quick_add: 'standard'
              %}
            </div>
          {%- endfor -%}
        {%- else -%}
          <article class="gexon-product-placeholder">
            <img src="{{ section.settings.placeholder_image_1 }}" alt="Commercial strength rack" width="900" height="900" loading="lazy">
            <div><span>Strength</span><strong>Commercial Power Rack</strong><em>Quote available</em></div>
          </article>
          <article class="gexon-product-placeholder">
            <img src="{{ section.settings.placeholder_image_2 }}" alt="Cardio treadmill" width="900" height="900" loading="lazy">
            <div><span>Cardio</span><strong>Performance Treadmill</strong><em>Quote available</em></div>
          </article>
          <article class="gexon-product-placeholder">
            <img src="{{ section.settings.placeholder_image_3 }}" alt="Dumbbell set" width="900" height="900" loading="lazy">
            <div><span>Free weights</span><strong>Dumbbell Training Set</strong><em>Quote available</em></div>
          </article>
          <article class="gexon-product-placeholder">
            <img src="{{ section.settings.placeholder_image_4 }}" alt="Cable machine" width="900" height="900" loading="lazy">
            <div><span>Functional</span><strong>Functional Trainer</strong><em>Quote available</em></div>
          </article>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="gexon-solution-grid">
    <section class="gexon-solution-card" style="--solution-image: url('{{ section.settings.commercial_image_url }}');">
      <div>
        <p class="gexon-eyebrow">Commercial gym solutions</p>
        <h2>{{ section.settings.commercial_heading }}</h2>
        <p>{{ section.settings.commercial_text }}</p>
        <a class="button button--primary" href="{{ section.settings.commercial_link }}">{{ section.settings.commercial_label }}</a>
      </div>
    </section>
    <section class="gexon-solution-card gexon-solution-card--red" style="--solution-image: url('{{ section.settings.home_gym_image_url }}');">
      <div>
        <p class="gexon-eyebrow">Home gym equipment</p>
        <h2>{{ section.settings.home_gym_heading }}</h2>
        <p>{{ section.settings.home_gym_text }}</p>
        <a class="button button--secondary" href="{{ section.settings.home_gym_link }}">{{ section.settings.home_gym_label }}</a>
      </div>
    </section>
  </div>

  <div class="gexon-section gexon-section--dark">
    <div class="page-width">
      <div class="gexon-section-heading">
        <p class="gexon-eyebrow">Why choose GEXON</p>
        <h2>Reliable equipment sourcing for serious training spaces</h2>
      </div>
      <div class="gexon-feature-grid">
        {%- assign feature_number = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_card' -%}
            {%- assign feature_number = feature_number | plus: 1 -%}
            <article class="gexon-feature-card" {{ block.shopify_attributes }}>
              <span>{{ feature_number }}</span>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="gexon-quote" id="gexon-contact">
    <div class="page-width gexon-quote__inner">
      <div>
        <p class="gexon-eyebrow">Request a quote</p>
        <h2>{{ section.settings.quote_heading }}</h2>
        <p>{{ section.settings.quote_text }}</p>
      </div>
      <a class="button button--primary" href="{{ section.settings.quote_link }}">{{ section.settings.quote_label }}</a>
    </div>
  </div>
</section>

{% stylesheet %}
  .gexon-home {
    --gexon-black: #0b0b0b;
    --gexon-black-2: #151515;
    --gexon-red: #e53935;
    --gexon-white: #ffffff;
    background: var(--gexon-black);
    color: var(--gexon-white);
  }

  .gexon-hero {
    position: relative;
    min-height: clamp(32rem, 31vw, 43rem);
    display: grid;
    align-items: center;
    overflow: hidden;
    background: var(--gexon-black);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .gexon-hero__image,
  .gexon-hero__photo,
  .gexon-hero__overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .gexon-hero__image,
  .gexon-hero__photo {
    object-fit: cover;
  }

  .gexon-hero__photo {
    background-image: var(--gexon-hero-image);
    background-size: cover;
    background-position: center right;
    transform: scale(1.02);
  }

  .gexon-hero__overlay {
    background:
      linear-gradient(90deg, rgba(4, 4, 4, 0.96), rgba(7, 7, 7, 0.74) 38%, rgba(7, 7, 7, 0.22) 72%),
      linear-gradient(0deg, rgba(4, 4, 4, 0.72), rgba(4, 4, 4, 0.08) 48%, rgba(4, 4, 4, 0.48)),
      radial-gradient(circle at 72% 40%, rgba(229, 57, 53, 0.16), transparent 30%);
  }

  .gexon-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    justify-self: center;
    padding-top: 4.4rem;
    padding-bottom: 5.4rem;
  }

  .gexon-eyebrow {
    margin: 0 0 1.2rem;
    color: var(--gexon-red);
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gexon-hero h1 {
    max-width: 56rem;
    margin: 0;
    color: var(--gexon-white);
    font-size: clamp(3.4rem, 4.2vw, 6.2rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .gexon-hero p:not(.gexon-eyebrow) {
    max-width: 53rem;
    margin: 1.4rem 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.45rem;
    line-height: 1.5;
  }

  .gexon-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.2rem;
  }

  .gexon-home .button {
    min-height: 4.2rem;
    min-width: 14.4rem;
    padding: 0 1.8rem;
    border-radius: 0;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .gexon-home .button--primary {
    --color-button: 229, 57, 53;
    --color-button-text: 255, 255, 255;
  }

  .gexon-home .button--secondary {
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.04);
  }

  .gexon-hero__brand {
    position: absolute;
    z-index: 2;
    top: 29%;
    right: clamp(3rem, 10vw, 14rem);
    width: clamp(18rem, 24vw, 36rem);
    opacity: 0.94;
    filter: drop-shadow(0 1.2rem 2rem rgba(0, 0, 0, 0.55));
  }

  .gexon-hero__brand img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gexon-hero__dots {
    position: absolute;
    z-index: 3;
    right: 0;
    bottom: 2.1rem;
    left: 0;
    display: flex;
    justify-content: center;
    gap: 0.7rem;
  }

  .gexon-hero__dots span {
    width: 2rem;
    height: 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.42);
  }

  .gexon-hero__dots .is-active {
    background: var(--gexon-red);
  }

  .gexon-section {
    padding: 7.2rem 0;
  }

  .gexon-section--dark {
    background: var(--gexon-black);
  }

  .gexon-section--products {
    background: var(--gexon-black-2);
    padding: 3.6rem 0;
  }

  .gexon-section--products .gexon-section-heading {
    margin-bottom: 1.6rem;
  }

  .gexon-section-heading {
    margin-bottom: 3.2rem;
  }

  .gexon-section-heading h2 {
    max-width: 900px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(3.2rem, 5vw, 5.8rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .gexon-section-heading--split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 3rem;
    align-items: end;
  }

  .gexon-text-link {
    color: var(--gexon-red);
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  .gexon-category-showcase {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.4rem;
  }

  .gexon-category-tile {
    position: relative;
    min-height: 34rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.2rem;
    overflow: hidden;
    color: #ffffff;
    text-decoration: none;
    background: #1d1d1d;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .gexon-category-tile::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(0deg, rgba(11, 11, 11, 0.96), rgba(11, 11, 11, 0.24)), var(--tile-image);
    background-size: cover;
    background-position: center;
    transition: transform 220ms ease;
  }

  .gexon-category-tile:hover::before {
    transform: scale(1.05);
  }

  .gexon-category-tile span,
  .gexon-category-tile strong {
    position: relative;
    z-index: 1;
  }

  .gexon-category-tile span {
    color: var(--gexon-red);
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .gexon-category-tile strong {
    max-width: 18rem;
    margin-top: 0.8rem;
    font-size: 2.2rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .gexon-product-grid,
  .gexon-feature-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .gexon-product .card__inner {
    height: 17rem;
    min-height: 0;
  }

  .gexon-product .card__inner.ratio::before {
    padding-bottom: 0;
  }

  .gexon-product .card__content {
    padding: 0.8rem 1rem;
  }

  .gexon-product .card__information {
    padding: 0.8rem 0;
  }

  .gexon-product .card__heading {
    font-size: 1.4rem;
    line-height: 1.15;
  }

  .gexon-product .card-information > .price {
    margin-top: 0.4rem;
  }

  .gexon-product-placeholder {
    overflow: hidden;
    background: #0f0f0f;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .gexon-product-placeholder img {
    width: 100%;
    height: 17rem;
    object-fit: cover;
    display: block;
  }

  .gexon-product-placeholder div {
    padding: 0.9rem 1rem 1rem;
  }

  .gexon-product-placeholder span {
    color: var(--gexon-red);
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .gexon-product-placeholder strong,
  .gexon-product-placeholder em {
    display: block;
    color: #ffffff;
  }

  .gexon-product-placeholder strong {
    margin-top: 0.4rem;
    font-size: 1.4rem;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .gexon-product-placeholder em {
    margin-top: 0.5rem;
    color: rgba(255, 255, 255, 0.66);
    font-style: normal;
  }

  .gexon-solution-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gexon-solution-card {
    position: relative;
    min-height: 54rem;
    display: grid;
    align-items: end;
    padding: clamp(3rem, 5vw, 7rem);
    overflow: hidden;
    background: #101010;
  }

  .gexon-solution-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(0deg, rgba(11, 11, 11, 0.95), rgba(11, 11, 11, 0.36)), var(--solution-image);
    background-size: cover;
    background-position: center;
  }

  .gexon-solution-card--red::before {
    background-image: linear-gradient(0deg, rgba(11, 11, 11, 0.94), rgba(229, 57, 53, 0.24)), var(--solution-image);
  }

  .gexon-solution-card > div {
    position: relative;
    z-index: 1;
    max-width: 66rem;
  }

  .gexon-solution-card h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(3rem, 4vw, 5rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .gexon-solution-card p:not(.gexon-eyebrow),
  .gexon-quote p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.7rem;
  }

  .gexon-feature-card {
    padding: 2.4rem;
    background: #151515;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .gexon-feature-card span {
    display: inline-grid;
    place-items: center;
    width: 4.4rem;
    height: 4.4rem;
    margin-bottom: 2.6rem;
    background: var(--gexon-red);
    color: #ffffff;
    font-weight: 900;
  }

  .gexon-feature-card h3 {
    margin: 0;
    color: #ffffff;
    font-size: 2rem;
    text-transform: uppercase;
  }

  .gexon-feature-card p {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.68);
  }

  .gexon-quote {
    padding: 6.4rem 0;
    background: var(--gexon-red);
  }

  .gexon-quote__inner {
    display: flex;
    gap: 3rem;
    align-items: center;
    justify-content: space-between;
  }

  .gexon-quote h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(3rem, 5vw, 5.2rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .gexon-quote .gexon-eyebrow {
    color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .gexon-hero__brand {
      right: 3rem;
      width: 20rem;
      opacity: 0.62;
    }

    .gexon-category-showcase,
    .gexon-product-grid,
    .gexon-feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gexon-solution-grid,
    .gexon-section-heading--split {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .gexon-hero {
      min-height: 48rem;
    }

    .gexon-hero__content {
      padding-top: 5.6rem;
      padding-bottom: 7rem;
    }

    .gexon-hero h1 {
      font-size: clamp(3.2rem, 11vw, 4.8rem);
    }

    .gexon-hero__brand {
      top: auto;
      right: 2rem;
      bottom: 6.2rem;
      width: 15rem;
      opacity: 0.32;
    }

    .gexon-section {
      padding: 5rem 0;
    }

    .gexon-category-showcase,
    .gexon-product-grid,
    .gexon-feature-grid {
      grid-template-columns: 1fr;
    }

    .gexon-category-tile {
      min-height: 25rem;
    }

    .gexon-solution-card {
      min-height: 42rem;
    }

    .gexon-quote__inner {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "GEXON home",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_image_url", "label": "Default hero image URL", "default": "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=2400&q=85" },
    { "type": "text", "id": "hero_kicker", "label": "Hero small title", "default": "GEXON PERFORMANCE EQUIPMENT" },
    { "type": "text", "id": "hero_heading", "label": "Hero title", "default": "ONE-STOP FITNESS EQUIPMENT SOLUTION" },
    { "type": "textarea", "id": "hero_text", "label": "Hero description", "default": "Commercial-grade strength, cardio, and functional training equipment for gyms, studios, and home athletes." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "SHOP EQUIPMENT" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "REQUEST A QUOTE" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "collection", "id": "featured_collection", "label": "Featured products collection" },
    { "type": "text", "id": "featured_heading", "label": "Featured heading", "default": "Featured products" },
    { "type": "url", "id": "featured_link", "label": "Featured link" },
    { "type": "text", "id": "placeholder_image_1", "label": "Placeholder product image 1", "default": "https://images.unsplash.com/photo-1596357395217-80de13130e92?auto=format&fit=crop&w=900&q=80" },
    { "type": "text", "id": "placeholder_image_2", "label": "Placeholder product image 2", "default": "https://images.unsplash.com/photo-1576678927484-cc907957088c?auto=format&fit=crop&w=900&q=80" },
    { "type": "text", "id": "placeholder_image_3", "label": "Placeholder product image 3", "default": "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=900&q=80" },
    { "type": "text", "id": "placeholder_image_4", "label": "Placeholder product image 4", "default": "https://images.unsplash.com/photo-1593079831268-3381b0db4a77?auto=format&fit=crop&w=900&q=80" },
    { "type": "text", "id": "commercial_image_url", "label": "Commercial image URL", "default": "https://images.unsplash.com/photo-1540497077202-7c8a3999166f?auto=format&fit=crop&w=1600&q=85" },
    { "type": "text", "id": "commercial_heading", "label": "Commercial heading", "default": "BUILD YOUR PROFESSIONAL GYM WITH GEXON" },
    { "type": "textarea", "id": "commercial_text", "label": "Commercial text", "default": "From strength machines to cardio equipment, we help gyms, hotels, studios, and training centers source reliable fitness equipment." },
    { "type": "text", "id": "commercial_label", "label": "Commercial button label", "default": "CONTACT US" },
    { "type": "url", "id": "commercial_link", "label": "Commercial button link" },
    { "type": "text", "id": "home_gym_image_url", "label": "Home gym image URL", "default": "https://images.unsplash.com/photo-1591291621164-2c6367723315?auto=format&fit=crop&w=1600&q=85" },
    { "type": "text", "id": "home_gym_heading", "label": "Home gym heading", "default": "PREMIUM EQUIPMENT FOR HOME TRAINING" },
    { "type": "textarea", "id": "home_gym_text", "label": "Home gym text", "default": "Create a complete home gym with treadmills, exercise bikes, benches, dumbbells, racks, and accessories." },
    { "type": "text", "id": "home_gym_label", "label": "Home gym button label", "default": "SHOP HOME GYM" },
    { "type": "url", "id": "home_gym_link", "label": "Home gym button link" },
    { "type": "text", "id": "quote_heading", "label": "Quote heading", "default": "NEED HELP CHOOSING EQUIPMENT?" },
    { "type": "textarea", "id": "quote_text", "label": "Quote text", "default": "Tell us your space, budget, and training needs. We will help you find the right fitness equipment solution." },
    { "type": "text", "id": "quote_label", "label": "Quote button label", "default": "CONTACT GEXON" },
    { "type": "url", "id": "quote_link", "label": "Quote button link" }
